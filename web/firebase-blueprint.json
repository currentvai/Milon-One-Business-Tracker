{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User specific settings and metadata.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "lastActiveBusinessId": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Business": {
      "title": "Business",
      "description": "A business entity managed by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sheetId": { "type": "string" },
        "lastSyncedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "categories": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "buyPrice": { "type": "number" },
        "sellPrice": { "type": "number" },
        "stock": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "buyPrice", "sellPrice", "stock"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Purchase or Sales record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["purchase", "sale"] },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "total": { "type": "number" },
        "profit": { "type": "number" },
        "customerName": { "type": "string" },
        "paidAmount": { "type": "number" },
        "dueAmount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "productId", "quantity", "price", "total", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/users/{userId}/businesses/{businessId}": {
      "schema": "Business",
      "description": "User's business entities"
    },
    "/users/{userId}/businesses/{businessId}/products/{productId}": {
      "schema": "Product",
      "description": "Business inventory products"
    },
    "/users/{userId}/businesses/{businessId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Business purchase and sales history"
    }
  }
}
